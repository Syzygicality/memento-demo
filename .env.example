# Ledger backend configuration.
#
# Every backend variable is documented here. Copy to `.env` and fill in local
# values. Configuration is read exclusively through the composed `settings`
# object (backend/config/config.py) — never os.environ directly.

# --- Database ---
# The full async DSN is preferred; if omitted it is assembled from the parts.
LEDGER_DATABASE_URL=postgresql+asyncpg://ledger:ledger@localhost:5432/ledger
LEDGER_DATABASE_HOST=localhost
LEDGER_DATABASE_PORT=5432
LEDGER_DATABASE_NAME=ledger
LEDGER_DATABASE_USER=ledger
LEDGER_DATABASE_PASSWORD=ledger

# --- API / runtime ---
LEDGER_ENV=dev                 # dev | prod
LEDGER_LOG_LEVEL=INFO
LEDGER_WORKERS=4               # uvicorn workers in prod mode
LEDGER_CORS_ORIGINS=http://localhost:5173

# --- Auth (tenant resolution) ---
# HMAC secret for signing tenant session tokens. Fill in locally; never commit.
LEDGER_AUTH_SECRET=

# --- Idempotency ---
# Max lifetime of an idempotency record before the sweeper may reclaim it.
LEDGER_IDEMPOTENCY_TTL_HOURS=48
# The sweep never deletes keys younger than this in-flight window.
LEDGER_IDEMPOTENCY_MIN_AGE_MINUTES=15
